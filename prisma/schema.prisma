generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// User
// Role
// Employee
// Department
// Designation

model Department {
  id        Int       @id @default(autoincrement())
  title     String
  statusId  Int
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  companyId Int       @default(1) @map("company_id")
  branchId  Int       @default(1) @map("branch_id")
  employees Employee[]

  @@map("departments")
}

model Designation {
  id         Int       @id @default(autoincrement())
  title      String    @db.VarChar(100)
  status_id  Int
  created_at DateTime? @db.Timestamp(6)
  updated_at DateTime? @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)
  company_id Int?      @default(1)
  branch_id  Int?      @default(1)
  employees Employee[]

  @@map("designations")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  phone    String?
  password String

  // roleId  Int @default(3)
  // role  Role @relation(fields:[roleId],references: [id])
  // isAdmin Boolean @default(false)
  globalRoleId Int?
  globalRole  GlobalRole? @relation(fields: [globalRoleId], references: [id])


  status   UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt   DateTime?
  deletedAt     DateTime?
  employee    Employee?
  // attendances Attendance[]
}

model GlobalRole{
  id       Int       @id @default(autoincrement())
  name     String @unique
  description String?
   users      User[]
}

// model UserGlobalRole{

// }
model Role {
  id        Int      @id @default(autoincrement())
  companyId Int 

  name      String   @unique  // Admin, HR, Employee
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  employees Employee[]

  
}
enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
model Employee {
  id     Int @id @default(autoincrement())
  userId Int? @unique
 user User? @relation(fields: [userId], references: [id])
 companyId Int 
 name String 
 phone String?
 email String? @unique
 roleId Int @default(1)
 role Role @relation(fields:[roleId], references: [id])
 status EmployeeStatus @default(ACTIVE)
  employeeCode  String?
  departmentId  Int?
  department  Department? @relation(fields: [departmentId], references: [id])
  designationId Int?
  designation Designation? @relation(fields: [designationId], references: [id])
  // managerId     Int?

  joiningDate    DateTime?
  // employmentType String? // Permanent, Contractual
  // status         String? // active, resigned
    createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
@@index([companyId])
  
  
  
}

model Attendance {
  id     Int      @id @default(autoincrement())
  userId Int
  date   DateTime

  checkIn  DateTime?
  checkOut DateTime?

  status String? // Present, Late

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // user User @relation(fields: [userId], references: [id])npx prisma migrate dev --name add_role

  @@unique([userId, date]) // 🔥 important
}

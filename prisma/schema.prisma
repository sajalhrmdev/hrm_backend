generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id        Int       @id @default(autoincrement())
  title     String
  statusId  Int
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  companyId Int       @default(1) @map("company_id")
  branchId  Int       @default(1) @map("branch_id")
  employees Employee[]

  @@map("departments")
}

model Designation {
  id         Int       @id @default(autoincrement())
  title      String    @db.VarChar(100)
  status_id  Int
  created_at DateTime? @db.Timestamp(6)
  updated_at DateTime? @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)
  company_id Int?      @default(1)
  branch_id  Int?      @default(1)
  employees Employee[]

  @@map("designations")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  phone    String?
  password String

  roleId  Int @default(3)
  role  Role @relation(fields:[roleId],references: [id])
  isAdmin Boolean @default(false)

  statusId Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee    Employee?
  attendances Attendance[]
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique  // Admin, HR, Employee

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]   //  relation
}

model Employee {
  id     Int @id @default(autoincrement())
  userId Int @unique

  employeeCode  String?
  departmentId  Int?
  department  Department? @relation(fields: [departmentId], references: [id])
  designationId Int?
  designation Designation? @relation(fields: [designationId], references: [id])
  managerId     Int?

  joiningDate    DateTime?
  employmentType String? // Permanent, Contractual
  status         String? // active, resigned

  user User @relation(fields: [userId], references: [id])
  
  
}

model Attendance {
  id     Int      @id @default(autoincrement())
  userId Int
  date   DateTime

  checkIn  DateTime?
  checkOut DateTime?

  status String? // Present, Late

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date]) // 🔥 important
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// User
// Role
// Employee
// Department
// Designation

model Department {
  id        Int       @id @default(autoincrement())
  title     String
  statusId  Int
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  companyId Int       @default(1) @map("company_id")
  branchId  Int       @default(1) @map("branch_id")
  employees Employee[]

  @@map("departments")
}

model Designation {
  id         Int       @id @default(autoincrement())
  title      String    @db.VarChar(100)
  status_id  Int
  created_at DateTime? @db.Timestamp(6)
  updated_at DateTime? @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)
  company_id Int?      @default(1)
  branch_id  Int?      @default(1)
  employees Employee[]

  @@map("designations")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  phone    String?
  password String

  // roleId  Int @default(3)
  // role  Role @relation(fields:[roleId],references: [id])
  // isAdmin Boolean @default(false)
  globalRoleId Int?
  globalRole  GlobalRole? @relation(fields: [globalRoleId], references: [id])


  status   UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt   DateTime?
  deletedAt     DateTime?
  employee    Employee?
  // attendances Attendance[]
}

model GlobalRole{
  id       Int       @id @default(autoincrement())
  name     String @unique
  description String?
   users      User[]
}

// model UserGlobalRole{

// }

// ===================================COMPANY======================================
enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
model Company{
  id     Int  @id @default(autoincrement())
  name   String
  slug   String @unique
  email  String
  phone  String
  address String
  status CompanyStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  employees Employee[]
  roles     Role[]
  attendances Attendance[]
  attendanceLogs AttendanceLog[]
  workPolicies WorkPolicy[]
  CompanySettings CompanySetting[]
  Shifts Shift[]
  SalaryStractures SalaryStracture[]
  payRollRuns PayRollRun[]



}
// ============================================================================================
model Role {
  id        Int      @id @default(autoincrement())
  companyId Int 
  company Company @relation(fields: [companyId],references: [id])

  name      String   @unique  // Admin, HR, Employee
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  employees Employee[]

  
}
enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
model Employee {
  id     Int @id @default(autoincrement())
  userId Int? @unique
 user User? @relation(fields: [userId], references: [id])
 companyId Int 
 company Company @relation(fields: [companyId],references: [id])
 name String 
 phone String
 email String @unique 
 roleId Int @default(1)
 role Role @relation(fields:[roleId], references: [id])
 status EmployeeStatus @default(ACTIVE)
  employeeCode  String?
  departmentId  Int?
  department  Department? @relation(fields: [departmentId], references: [id])
  designationId Int?
  designation Designation? @relation(fields: [designationId], references: [id])
  // managerId     Int?

  joiningDate    DateTime?
  // employmentType String? // Permanent, Contractual
  // status         String? // active, resigned
    createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  attendances Attendance[]
  attendanceLogs AttendanceLog[]
  SalaryStracture SalaryStracture[]
  payRolls PayRoll[]
@@index([companyId])
  
  
  
}

// =================================ATTENDANCE====================================
model Attendance{
  id     Int @id @default(autoincrement())
  employeeId Int
  employee Employee @relation(fields: [employeeId],references: [id])
  companyId Int
  company Company @relation(fields: [companyId],references: [id])

  date DateTime
  status String  

  total_work_minutes Int @default(0)
  overtime_minutes Int @default(0)
  late_minutes Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  attendanceLogs AttendanceLog[]
  @@unique([employeeId,date])
}
// =======================================================================================

// ========================================ATTENDANCE LOG====================================
model AttendanceLog{
  id     Int @id @default(autoincrement())
   employeeId Int
  employee Employee @relation(fields: [employeeId],references: [id])
  companyId Int
  company Company @relation(fields: [companyId],references: [id])
  // ***** pore ? hatate hobe
    attendanceId Int?  // 🔥 foreign key
  attendance Attendance? @relation(fields: [attendanceId], references: [id])
// in/out--
  type String  
   latitude  Float?
  longitude Float?
  time DateTime
  source String?
  createdAt DateTime @default(now())
}
// ============================================================================================

// ========================================WORKPOLICY=============================================
enum AttendanceMode {
  SINGLE
  MULTI
}
model WorkPolicy{
   id     Int @id @default(autoincrement())
     companyId Int
  company Company @relation(fields: [companyId],references: [id])
  std_work_minutes Int
  overtime_minutes Int
  late_minutes Int
  half_day_threshold Int
  attendance_mode AttendanceMode @default(MULTI)
  createdAt DateTime @default(now())
}
// =====================================================================================================

// ===========================================COMPANY SETTINGS=============================================
model CompanySetting{
  id     Int @id @default(autoincrement())
     companyId Int
  company Company @relation(fields: [companyId],references: [id])
  config Json
    createdAt DateTime @default(now())
     updatedAt DateTime @updatedAt
}
// ============================================================================================================

// ================================================SHIFT=========================================================
model Shift{
  id     Int @id @default(autoincrement())
   companyId Int
  company Company @relation(fields: [companyId],references: [id])
  name String
  start_time Int
  end_time Int
  grace_minutes Int
}
// ===================================================================================================================

// ===================================================EMPLOYEE SALARY=================================================
model SalaryStracture{
id     Int @id @default(autoincrement())

 companyId Int
  company Company @relation(fields: [companyId],references: [id])
  employeeId Int @unique
  employee Employee @relation(fields: [employeeId],references: [id])

  monthly_salary Float
  effective_from DateTime
   createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// ====================================================================================================================

// ===================================================PAYROLL============================================================
model PayRoll{
  id     Int @id @default(autoincrement())
  payroll_run_id Int
 payrollRun PayRollRun @relation(fields: [payroll_run_id], references: [id])
 
  employeeId Int 
  employee Employee @relation(fields: [employeeId],references: [id])
  total_days Int
  present_days Int
  paid_leave_days Int
  lop_days Int
  payble_days Int
  gross_salary Float
  base_salary Float
  deduction Float
  net_salary Float
   createdAt DateTime @default(now())
   
}
// =====================================================================================================================

// ===================================================PAY ROLE RUN=====================================================
enum PayrollRunStatus {
  DRAFT
  FINAL
}
model PayRollRun{
   id     Int @id @default(autoincrement())
   companyId Int
  company Company @relation(fields: [companyId],references: [id])
  month Int
  year Int
  status PayrollRunStatus @default(DRAFT)
  payrolls PayRoll[]
  @@unique([companyId, month, year])
}